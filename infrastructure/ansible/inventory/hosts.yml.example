# ShieldOps Ansible Inventory
# Generate from Terraform: terraform output -raw ansible_inventory > inventory/hosts.yml
#
# Manual setup: Replace <NODE1_IP> and <NODE2_IP> with actual IPs

all:
  children:
    k3s_cluster:
      children:
        control_plane:
          hosts:
            shieldops-ctrl:
              ansible_host: <NODE1_IP>
        workers:
          hosts:
            shieldops-work:
              ansible_host: <NODE2_IP>

  vars:
    ansible_user: ubuntu
    ansible_ssh_private_key_file: ~/.ssh/shieldops
    ansible_python_interpreter: /usr/bin/python3